# ---------------------------------------------------------------------------
# SWE-bench Agent Pipeline — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control — add it to .gitignore.
#
# Cost estimates (actual runs):
#   Dev set  (23 instances)  — ~$9-$15
#   Test set (300 instances) — ~$260
#
# Recommended workflow:
#   1. Set INSTANCE_IDS= to a single instance to validate end-to-end
#   2. Run full dev set to tune prompts
#   3. Run test set for final evaluation

# ---------------------------------------------------------------------------
# Anthropic
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_api_key_here

# GitHub token — used to pull/push code from EC2 or other cloud environments
GITHUB_ACCESS_TOKEN=your_github_token_here

# ---------------------------------------------------------------------------
# Models
# ---------------------------------------------------------------------------
# Available models (as of April 2026):
#   claude-haiku-4-5-20251001   — cheapest, fast, mechanical tasks
#   claude-sonnet-4-20250514    — best cost/performance, strong reasoning
#   claude-sonnet-4-6           — most capable, use for Critic

# Default fallback if per-agent model not set
MODEL=claude-sonnet-4-20250514

# Per-agent model overrides
LOCALIZATION_MODEL=claude-sonnet-4-20250514  # strong reasoning needed for code exploration
ARCHITECT_MODEL=claude-sonnet-4-20250514     # strong reasoning needed for fix design
EDITOR_MODEL=claude-haiku-4-5-20251001       # mechanical implementation task — Haiku sufficient
CRITIC_MODEL=claude-sonnet-4-6               # most capable model as gatekeeper/judge

# ---------------------------------------------------------------------------
# Dataset
# ---------------------------------------------------------------------------
DATASET_NAME=princeton-nlp/SWE-bench_Lite

# dev  — 23 instances. Use for prompt development and tuning.
# test — 300 instances. Use for final leaderboard evaluation.
SPLIT=dev

# Run identifier — used for log directory naming
RUN_ID=agentloop

# Optional comma-separated instance IDs to run. Leave empty to run full split.
# Example: INSTANCE_IDS=sqlfluff__sqlfluff-1625,pydicom__pydicom-1256
INSTANCE_IDS=

# Comma-separated instance IDs to skip entirely (e.g. broken environments).
# Example: SKIP_INSTANCES=pvlib__pvlib-python-1072
SKIP_INSTANCES=

# ---------------------------------------------------------------------------
# Pipeline loop
# ---------------------------------------------------------------------------
# Maximum Architect → Editor → Critic cycles per instance before giving up.
PIPELINE_MAX_FIX_CYCLES=3

# ---------------------------------------------------------------------------
# Agent iteration and retry limits
# ---------------------------------------------------------------------------
# MAX_RETRIES: how many times to retry an agent if it fails to produce output
# MAX_ITERATIONS: max tool calls per agent attempt

LOCALIZATION_MAX_RETRIES=2
LOCALIZATION_MAX_ITERATIONS=8

ARCHITECT_MAX_RETRIES=2
ARCHITECT_MAX_ITERATIONS=10

EDITOR_MAX_RETRIES=2
EDITOR_MAX_ITERATIONS=10

CRITIC_MAX_RETRIES=2
CRITIC_MAX_ITERATIONS=10

# Global iteration cap — applies if per-agent override not set
MAX_ITERATIONS=10

# ---------------------------------------------------------------------------
# State directories — all agents write JSON state files here
# ---------------------------------------------------------------------------
# All agents default to ./states — change to use Modal Volume mount point
# when running on Modal (e.g. /states)
LOCALIZATION_STATE_DIR=./states
ARCHITECT_STATE_DIR=./states
EDITOR_STATE_DIR=./states
CRITIC_STATE_DIR=./states

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_DIR=./logs

# ---------------------------------------------------------------------------
# Context window cost control
# ---------------------------------------------------------------------------
# Summarize conversation every N tool calls to compress context.
# Set to 0 to disable (recommended — only enable for very long runs).
SUMMARIZE_EVERY=0

# ---------------------------------------------------------------------------
# Execution mode
# ---------------------------------------------------------------------------
# false — sequential, immediate results. Use for development.
# true  — turn-level batch (50% cheaper, ~1hr/turn). Use for large evaluation runs.
BATCH_MODE=false
BATCH_POLL_INTERVAL=60

# ---------------------------------------------------------------------------
# Modal configuration (only needed when using pipeline_modal.py)
# ---------------------------------------------------------------------------
# Max parallel instances on Modal. Keep below your Anthropic RPM / 6.
# Tier 2 (1000 RPM): safe up to ~10 containers
# Tier 3 (2000 RPM): safe up to ~20 containers
MODAL_MAX_CONTAINERS=10

# ---------------------------------------------------------------------------
# Predictions formatter
# ---------------------------------------------------------------------------
PREDICTIONS_PATH=predictions.jsonl
MODEL_NAME=claude-sonnet-swe-agent
